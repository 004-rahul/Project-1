@{
    ViewData["Title"] = "Home";
}

<div class="p-5 mb-4 bg-body-tertiary rounded-3 border">
    <div class="container-fluid py-3">
        <h1 class="display-6 fw-bold">Enterprise E-Commerce</h1>
        <p class="col-lg-9 fs-5 text-muted">
            A production-style e-commerce backend on ASP.NET Core 9 — clean architecture,
            SQL Server, JWT auth, Redis, RabbitMQ, SignalR and an AI product search.
            This page is rendered by the MVC layer; the same host also exposes a REST API.
        </p>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <h5 class="card-title mb-3">Built so far</h5>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item">✅ Clean layered architecture</li>
                    <li class="list-group-item">✅ SQL Server + EF Core persistence</li>
                    <li class="list-group-item">✅ Repository + unit-of-work</li>
                    <li class="list-group-item">✅ MVC UI (this page)</li>
                </ul>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <h5 class="card-title mb-3">Coming next</h5>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item">⏳ Product catalog — list &amp; create</li>
                    <li class="list-group-item">⏳ JWT login / logout + activity log</li>
                    <li class="list-group-item">⏳ Redis · RabbitMQ · SignalR · Firebase</li>
                    <li class="list-group-item">⏳ AI semantic product search</li>
                </ul>
            </div>
        </div>
    </div>
</div>
