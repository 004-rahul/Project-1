@using ECommerce.Api.Models
@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_AdminLayout";
}

<h1 class="h3 mb-4">Dashboard</h1>

<div class="row g-4">
    <div class="col-sm-6 col-lg-3">
        <div class="card shadow-sm">
            <div class="card-body position-relative">
                <div class="text-muted small">Products</div>
                <div class="display-6">@Model.ProductCount</div>
                <a asp-controller="AdminProducts" asp-action="Index" class="stretched-link"></a>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Orders</div><div class="display-6">—</div></div></div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Customers</div><div class="display-6">—</div></div></div>
    </div>
</div>
