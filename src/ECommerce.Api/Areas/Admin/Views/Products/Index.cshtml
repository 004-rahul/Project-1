@model IReadOnlyList<ProductDto>
@{
    ViewData["Title"] = "Manage products";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Manage products</h1>
    <a asp-action="Create" class="btn btn-primary">Add product</a>
</div>

@if (TempData["Message"] is string message)
{
    <div class="alert alert-success">@message</div>
}

<div class="table-responsive">
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th>SKU</th>
                <th>Category</th>
                <th class="text-end">Price</th>
                <th class="text-end">Stock</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td>@p.Name</td>
                    <td><code>@p.Sku</code></td>
                    <td>@p.CategoryName</td>
                    <td class="text-end">@p.Price.ToString("C")</td>
                    <td class="text-end">@p.StockQuantity</td>
                    <td>@p.Status</td>
                    <td class="text-end">
                        <form asp-action="Delete" asp-route-id="@p.Id" method="post"
                              onsubmit="return confirm('Delete @p.Name?');" class="d-inline">
                            <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
